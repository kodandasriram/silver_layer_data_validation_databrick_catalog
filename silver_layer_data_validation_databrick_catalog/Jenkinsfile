pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Python Version') {
            steps {
                bat '"C:\\Users\\MODICHERLA\\AppData\\Local\\Python\\bin\\python.exe" --version'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat '''
                "C:\\Users\\MODICHERLA\\AppData\\Local\\Python\\bin\\python.exe" -m venv venv
                call venv\\Scripts\\activate
                pip install -r silver_layer_data_validation_databrick_catalog\\requirements.txt
                '''
            }
        }

        stage('Run Python Script') {
            steps {
                bat '''
                call venv\\Scripts\\activate
                set VALIDATION_EMAIL_ENABLED=true
                set VALIDATION_EMAIL_SMTP_HOST=smtp.office365.com
                set VALIDATION_EMAIL_SMTP_PORT=587
                set VALIDATION_EMAIL_USE_TLS=true
                set VALIDATION_EMAIL_FROM=your_email@company.com
                set VALIDATION_EMAIL_TO=msriram@hexalytics.com
                set VALIDATION_EMAIL_SMTP_USER=your_email@company.com
                set VALIDATION_EMAIL_SMTP_PASSWORD=your_password_or_app_password
                python silver_layer_data_validation_databrick_catalog\\main_runner.py
                '''
            }
        }

        stage('Archive Output') {
            steps {
                archiveArtifacts artifacts: 'silver_layer_data_validation_databrick_catalog/output/**/*', allowEmptyArchive: true
            }
        }
    }
}
